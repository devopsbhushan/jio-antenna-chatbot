<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow AWS Lambda function URLs -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">lambda-url.ap-south-1.on.aws</domain>
        <domain includeSubdomains="true">amazonaws.com</domain>
        <domain includeSubdomains="true">s3.ap-south-1.amazonaws.com</domain>
    </domain-config>
</network-security-config>
